# ===========================
# BidStream Environment Variables
# ===========================
# Copy this file to .env and fill in your actual values

# ===========================
# Node Environment
# ===========================
NODE_ENV=development

# ===========================
# Database Configuration (MongoDB)
# ===========================
# For Docker Compose: mongodb://user:password@mongodb:27017/auction_db?authSource=admin
# For Local Development: mongodb://localhost:27017/auction_db
MONGODB_URI=mongodb://localhost:27017/auction_db

# MongoDB Authentication (used by Docker Compose)
MONGO_USER=auction_user
MONGO_PASSWORD=secure_password
MONGO_DB=auction_db
MONGO_PORT=27017

# ===========================
# Redis Configuration
# ===========================
# For Docker Compose: redis://:password@redis:6379
# For Local Development: redis://localhost:6379
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=redis_secure_password
REDIS_PORT=6379

# ===========================
# JWT Configuration
# ===========================
# Secret key for JWT signing - MUST be changed in production
JWT_SECRET=your_jwt_secret_key_change_this_in_production_to_something_long_and_random
# JWT token expiration time
JWT_EXPIRE=7d

# ===========================
# Server Configuration
# ===========================
PORT=3000
# Frontend URL for CORS
CLIENT_URL=http://localhost:5173

# ===========================
# CORS Configuration
# ===========================
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# ===========================
# Rate Limiting Configuration
# ===========================
# Time window in milliseconds (default: 15 minutes = 900000ms)
RATE_LIMIT_WINDOW_MS=900000
# Maximum requests per window
RATE_LIMIT_MAX_REQUESTS=500

# ===========================
# Cloudinary (Image Hosting) - Optional
# ===========================
# Leave empty if not using image uploads
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ===========================
# Email Configuration - Optional
# ===========================
# SMTP Configuration for sending emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
# Sender email address
SENDER_EMAIL=noreply@auction-platform.com

# ===========================
# Docker Container Ports - For docker-compose
# ===========================
BACKEND_PORT=3000
FRONTEND_PORT=5173

# ===========================
# Frontend Configuration - For docker-compose
# ===========================
VITE_API_URL=http://localhost:3000
