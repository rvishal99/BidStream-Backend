{
  "name": "auction-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Auction website backend with Node.js, Express, and MongoDB",
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js",
    "dev": "nodemon src/index.js",
    "seed": "node src/scripts/seedDatabase.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --detectOpenHandles --forceExit",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "bull": "^4.13.0",
    "cloudinary": "^1.21.0",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.14.0",
    "morgan": "^1.10.0",
    "multer": "^2.0.0",
    "multer-storage-cloudinary": "^4.0.0",
    "nodemon": "^3.1.14",
    "socket.io": "^4.8.1",
    "uuid": "^11.1.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "eslint": "^9.25.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3"
  }
}
